<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/cart.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main class="cart-page">
            <h1>Your Orders</h1>
            <% if (orders.length <= 0) { %>
                <div class="empty-state">
                    <h1>No orders yet</h1>
                    <a class="btn" href="/collections">Start Shopping</a>
                </div>
            <% } else { %>
                <div class="orders-list">
                    <% orders.forEach(order => { %>
                        <article class="order-card">
                            <header class="order-card__header">
                                <div>
                                    <h2>Order #<%= order.id %></h2>
                                    <p><%= order.createdAt.toLocaleString() %></p>
                                </div>
                                <div class="order-status"><%= order.paymentStatus || order.status %></div>
                            </header>
                            <div class="order-grid">
                                <div>
                                    <h3>Items</h3>
                                    <ul class="order-items">
                                        <% order.products.forEach(product => { %>
                                            <li>
                                                <span><%= product.title %> x <%= product.orderItem.quantity %></span>
                                                <strong>$<%= (Number(product.orderItem.price || product.price) * product.orderItem.quantity).toFixed(2) %></strong>
                                            </li>
                                        <% }); %>
                                    </ul>
                                </div>
                                <div>
                                    <h3>Shipping</h3>
                                    <p><strong><%= order.customerName || 'Address not saved' %></strong></p>
                                    <% if (order.addressLine1) { %>
                                        <p><%= order.addressLine1 %><% if (order.addressLine2) { %>, <%= order.addressLine2 %><% } %></p>
                                        <p><%= order.city %>, <%= order.state %> <%= order.postalCode %></p>
                                        <p><%= order.country %></p>
                                    <% } %>
                                </div>
                                <div>
                                    <h3>Payment</h3>
                                    <p>Total: <strong>$<%= Number(order.totalAmount).toFixed(2) %></strong></p>
                                    <p>PayPal ID: <%= order.paymentId || 'Pending' %></p>
                                    <% if (order.payerEmail) { %>
                                        <p>Payer: <%= order.payerEmail %></p>
                                    <% } %>
                                </div>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } %>
        </main>
        <%- include('../includes/end.ejs') %>
