<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/cart.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <form class="product-form" action="/profile" method="POST">
                <h1>Profile</h1>
                <div class="form-control">
                    <label for="name">Name</label>
                    <input type="text" name="name" id="name" value="<%= user.name || '' %>" required>
                </div>
                <div class="form-control">
                    <label for="email">Email</label>
                    <input type="email" id="email" value="<%= user.email %>" disabled>
                </div>
                <div class="form-control">
                    <label for="addressLine1">Address Line 1</label>
                    <input type="text" name="addressLine1" id="addressLine1" value="<%= user.addressLine1 || '' %>">
                </div>
                <div class="form-control">
                    <label for="addressLine2">Address Line 2</label>
                    <input type="text" name="addressLine2" id="addressLine2" value="<%= user.addressLine2 || '' %>">
                </div>
                <div class="form-grid">
                    <div class="form-control">
                        <label for="city">City</label>
                        <input type="text" name="city" id="city" value="<%= user.city || '' %>">
                    </div>
                    <div class="form-control">
                        <label for="state">State</label>
                        <input type="text" name="state" id="state" value="<%= user.state || '' %>">
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-control">
                        <label for="postalCode">Postal Code</label>
                        <input type="text" name="postalCode" id="postalCode" value="<%= user.postalCode || '' %>">
                    </div>
                    <div class="form-control">
                        <label for="country">Country Code</label>
                        <input type="text" name="country" id="country" maxlength="2" value="<%= user.country || 'US' %>">
                    </div>
                </div>
                <div class="form-control">
                    <label for="phone">Phone</label>
                    <input type="text" name="phone" id="phone" value="<%= user.phone || '' %>">
                </div>
                <button class="btn" type="submit">Save Profile</button>
            </form>
        </main>
        <%- include('../includes/end.ejs') %>
