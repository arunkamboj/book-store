<div class="backdrop"></div>
<header class="main-header">
    <a class="brand" href="/">
        <span class="brand__mark">B</span>
        <span class="brand__text">BookStore</span>
    </a>
    <button id="side-menu-toggle" aria-label="Open navigation">Menu</button>
    <nav class="main-header__nav">
        <ul class="main-header__item-list">
            <li class="main-header__item">
                <a class="<%= path === '/' ? 'active' : '' %>" href="/">Home</a>
            </li>
            <li class="main-header__item">
                <a class="<%= path === '/collections' ? 'active' : '' %>" href="/collections">Collections</a>
            </li>
            <li class="main-header__item">
                <a class="<%= path === '/product-list' ? 'active' : '' %>" href="/product-list">Products</a>
            </li>
           
            <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
                <li class="main-header__item">
                    <a class="<%= path === '/shop/cart' ? 'active' : '' %>" href="/cart">Cart</a>
                </li>
                <li class="main-header__item">
                    <a class="<%= path === '/orders' ? 'active' : '' %>" href="/orders">Orders</a>
                </li>
                <li class="main-header__item">
                    <a class="<%= path === '/profile' ? 'active' : '' %>" href="/profile">Profile</a>
                </li>
            <% } %>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                <li class="main-header__item nav-dropdown">
                    <button type="button">Admin</button>
                    <div class="nav-dropdown__menu">
                        <a class="<%= path === '/admin/add-product' ? 'active' : '' %>" href="/admin/add-product">Add Product</a>
                        <a class="<%= path === '/admin/product-list' ? 'active' : '' %>" href="/admin/product-list">Admin Products</a>
                        <a class="<%= path === '/admin/orders' ? 'active' : '' %>" href="/admin/orders">Manage Orders</a>
                        <a class="<%= path === '/admin/users' ? 'active' : '' %>" href="/admin/users">Manage Users</a>
                    </div>
                </li>
            <% } %>
            <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
                <li class="main-header__item">
                    <form class="nav-form" action="/logout" method="POST">
                        <button type="submit">Logout</button>
                    </form>
                </li>
            <% } else { %>
                <li class="main-header__item">
                    <a class="nav-login <%= path === '/login' ? 'active' : '' %>" href="/login">Login</a>
                </li>
            <% } %>
        </ul>
    </nav>
</header>

<nav class="mobile-nav">
    <a class="brand mobile-brand" href="/">
        <span class="brand__mark">B</span>
        <span class="brand__text">BookStore</span>
    </a>
    <ul class="mobile-nav__item-list">
        <li class="mobile-nav__item">
            <a class="<%= path === '/' ? 'active' : '' %>" href="/">Home</a>
        </li>
        <li class="mobile-nav__item">
            <a class="<%= path === '/collections' ? 'active' : '' %>" href="/collections">Collections</a>
        </li>
        <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
            <li class="mobile-nav__item">
                <a class="<%= path === '/shop/cart' ? 'active' : '' %>" href="/cart">Cart</a>
            </li>
            <li class="mobile-nav__item">
                <a class="<%= path === '/orders' ? 'active' : '' %>" href="/orders">Orders</a>
            </li>
            <li class="mobile-nav__item">
                <a class="<%= path === '/profile' ? 'active' : '' %>" href="/profile">Profile</a>
            </li>
        <% } %>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
            <li class="mobile-nav__label">Admin</li>
            <li class="mobile-nav__item">
                <a class="<%= path === '/admin/add-product' ? 'active' : '' %>" href="/admin/add-product">Add Product</a>
            </li>
            <li class="mobile-nav__item">
                <a class="<%= path === '/admin/product-list' ? 'active' : '' %>" href="/admin/product-list">Admin Products</a>
            </li>
            <li class="mobile-nav__item">
                <a class="<%= path === '/admin/orders' ? 'active' : '' %>" href="/admin/orders">Manage Orders</a>
            </li>
            <li class="mobile-nav__item">
                <a class="<%= path === '/admin/users' ? 'active' : '' %>" href="/admin/users">Manage Users</a>
            </li>
        <% } %>
        <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
            <li class="mobile-nav__item">
                <form class="nav-form" action="/logout" method="POST">
                    <button type="submit">Logout</button>
                </form>
            </li>
        <% } else { %>
            <li class="mobile-nav__item">
                <a class="<%= path === '/login' ? 'active' : '' %>" href="/login">Login</a>
            </li>
        <% } %>
    </ul>
</nav>
