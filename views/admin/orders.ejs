<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/cart.css">
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main class="cart-page">
            <h1>Manage Orders</h1>
            <% if (orders.length === 0) { %>
                <div class="empty-state">
                    <h1>No orders found</h1>
                </div>
            <% } else { %>
                <div class="orders-list">
                    <% orders.forEach(order => { %>
                        <article class="order-card">
                            <header class="order-card__header">
                                <div>
                                    <h2>Order #<%= order.id %></h2>
                                    <p><%= order.user ? order.user.email : 'Unknown customer' %></p>
                                </div>
                                <form action="/admin/orders/update-status" method="POST">
                                    <input type="hidden" name="orderId" value="<%= order.id %>">
                                    <select name="status">
                                        <% ['PAID', 'PROCESSING', 'SHIPPED', 'DELIVERED', 'CANCELLED'].forEach(status => { %>
                                            <option value="<%= status %>" <%= order.status === status ? 'selected' : '' %>><%= status %></option>
                                        <% }) %>
                                    </select>
                                    <button class="btn" type="submit">Update</button>
                                </form>
                            </header>
                            <div class="order-grid">
                                <div>
                                    <h3>Items</h3>
                                    <ul class="order-items">
                                        <% order.products.forEach(product => { %>
                                            <li>
                                                <span><%= product.title %> x <%= product.orderItem.quantity %></span>
                                                <strong>$<%= (Number(product.orderItem.price || product.price) * product.orderItem.quantity).toFixed(2) %></strong>
                                            </li>
                                        <% }) %>
                                    </ul>
                                </div>
                                <div>
                                    <h3>Shipping</h3>
                                    <p><strong><%= order.customerName || 'Not saved' %></strong></p>
                                    <% if (order.addressLine1) { %>
                                        <p><%= order.addressLine1 %></p>
                                        <p><%= order.city %>, <%= order.state %> <%= order.postalCode %></p>
                                    <% } %>
                                </div>
                                <div>
                                    <h3>Payment</h3>
                                    <p>Total: <strong>$<%= Number(order.totalAmount).toFixed(2) %></strong></p>
                                    <p>Status: <%= order.paymentStatus || order.status %></p>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                </div>
            <% } %>
        </main>
        <%- include('../includes/end.ejs') %>
